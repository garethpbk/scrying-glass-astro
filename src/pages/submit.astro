---
import BaseLayout from "../layouts/BaseLayout.astro";

const maxFileSizeMB = 10;
const acceptedExtensions = ".doc,.docx,.rtf,.pdf,.odt,.txt";
const acceptedMimeTypes =
  "application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/rtf,application/pdf,application/vnd.oasis.opendocument.text,text/plain";

const artMaxFileSizeMB = 5;
const artAcceptedExtensions = ".jpg,.jpeg,.png,.tiff,.tif,.bmp";
const artAcceptedMimeTypes = "image/jpeg,image/png,image/tiff,image/bmp";
---

<BaseLayout
  title="Submit ~ Scrying Glass"
  description="Submit your sword & sorcery manuscript or visual art to Scrying Glass."
>
  <h1>Submit Your Work</h1>

  <p class="intro" id="intro-text">
    Ready to send your work into the glass? Fill out the form below. Make sure
    you've reviewed our <a href="/submissions/">submission guidelines</a> first.
  </p>

  <form id="submission-form" novalidate enctype="multipart/form-data">
    <fieldset class="type-selector" id="type-selector">
      <legend>What are you submitting? <span class="required">*</span></legend>
      <div class="type-options">
        <label class="type-option selected">
          <input type="radio" name="submissionType" value="story" checked />
          <span class="type-label">Story</span>
          <span class="type-desc">A manuscript, with optional art</span>
        </label>
        <label class="type-option">
          <input type="radio" name="submissionType" value="art" />
          <span class="type-label">Art Only</span>
          <span class="type-desc">Visual art without a manuscript</span>
        </label>
      </div>
    </fieldset>

    <div class="form-group">
      <label for="author-name"
        >Author Name <span class="required">*</span></label
      >
      <input
        type="text"
        id="author-name"
        name="authorName"
        required
        placeholder="Your name or pen name"
        autocomplete="name"
      />
      <p class="field-error" id="author-name-error"></p>
    </div>

    <div class="form-group">
      <label for="email">Email <span class="required">*</span></label>
      <input
        type="email"
        id="email"
        name="email"
        required
        placeholder="you@example.com"
        autocomplete="email"
      />
      <p class="field-error" id="email-error"></p>
    </div>

    <div class="form-group" id="story-title-group">
      <label for="story-title">
        <span id="story-title-label">Story Title</span>
        <span class="required">*</span>
      </label>
      <input
        type="text"
        id="story-title"
        name="storyTitle"
        required
        placeholder="The title of your manuscript"
      />
      <p class="field-error" id="story-title-error"></p>
    </div>

    <div class="form-group" id="manuscript-group">
      <label for="manuscript">
        Manuscript <span class="required" id="manuscript-req">*</span>
      </label>
      <div class="file-upload-area" id="file-upload-area">
        <input
          type="file"
          id="manuscript"
          name="manuscript"
          required
          accept={`${acceptedExtensions},${acceptedMimeTypes}`}
        />
        <div class="file-upload-content">
          <span class="file-upload-icon">&#x1F4DC;</span>
          <p class="file-upload-text">
            <strong>Choose a file</strong> or drag it here
          </p>
          <p class="file-upload-hint">
            .doc, .docx, .rtf, .pdf, .odt, or .txt — max {maxFileSizeMB}MB
          </p>
        </div>
        <div class="file-upload-selected" id="file-selected" hidden>
          <span class="file-name" id="file-name"></span>
          <button
            type="button"
            class="file-remove"
            id="file-remove"
            aria-label="Remove file">&times;</button
          >
        </div>
      </div>
      <p class="field-error" id="manuscript-error"></p>
    </div>

    <div class="form-group">
      <label for="cover-letter">Brief Cover Letter</label>
      <textarea
        id="cover-letter"
        name="coverLetter"
        rows="4"
        placeholder="A few sentences about yourself and any publication credits (optional)"
      ></textarea>
    </div>

    <div class="form-group" id="art-group">
      <label for="art-attachment">
        Art Attachment <span class="required" id="art-req" hidden>*</span>
      </label>
      <p class="field-hint" id="art-hint">
        Optional — if you have visual art to accompany your story, attach it
        here. We print in <strong>single-color risograph</strong>, so complex
        multi-color works may not reproduce well. High-contrast, bold linework
        tends to look best.
      </p>
      <div class="file-upload-area" id="art-upload-area">
        <input
          type="file"
          id="art-attachment"
          name="artAttachment"
          accept={`${artAcceptedExtensions},${artAcceptedMimeTypes}`}
        />
        <div class="file-upload-content">
          <span class="file-upload-icon">&#x1F3A8;</span>
          <p class="file-upload-text">
            <strong>Choose an image</strong> or drag it here
          </p>
          <p class="file-upload-hint">
            .jpg, .png, .tiff, or .bmp — max {artMaxFileSizeMB}MB
          </p>
        </div>
        <div class="file-upload-selected" id="art-selected" hidden>
          <span class="file-name" id="art-file-name"></span>
          <button
            type="button"
            class="file-remove"
            id="art-remove"
            aria-label="Remove file">&times;</button
          >
        </div>
      </div>
      <p class="field-error" id="art-attachment-error"></p>
    </div>

    <div class="form-group">
      <label for="additional-notes">Anything else we should know?</label>
      <textarea
        id="additional-notes"
        name="additionalNotes"
        rows="3"
        placeholder="Simultaneous submission notice, content warnings, etc. (optional)"
      ></textarea>
    </div>

    <button type="submit" class="submit-btn" id="submit-btn">
      Send Into the Glass
    </button>
  </form>

  <div class="form-message" id="form-message" hidden></div>
</BaseLayout>

<style>
  h1 {
    text-align: center;
    margin-bottom: 1rem;
  }

  .intro {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  form {
    max-width: 36rem;
    margin: 0 auto;
  }

  .type-selector {
    border: 1px solid rgba(184, 184, 204, 0.2);
    border-radius: 0.5rem;
    padding: 1.25rem 1.5rem;
    margin-bottom: 2rem;
  }

  .type-selector legend {
    font-family: var(--font-ui);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-bone);
    letter-spacing: 0.02em;
    padding: 0 0.25rem;
  }

  .type-options {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    margin-top: 0.75rem;
  }

  .type-option {
    display: block;
    padding: 0.75rem 1rem;
    border: 1px solid rgba(184, 184, 204, 0.2);
    border-radius: 0.375rem;
    cursor: pointer;
    transition:
      border-color 0.2s ease,
      background-color 0.2s ease;
    margin-bottom: 0;
  }

  .type-option:hover {
    border-color: rgba(184, 184, 204, 0.4);
  }

  .type-option.selected {
    border-color: var(--color-crystal);
    background-color: rgba(46, 184, 255, 0.06);
  }

  .type-option input[type="radio"] {
    display: none;
  }

  .type-label {
    display: block;
    font-family: var(--font-ui);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-bone);
  }

  .type-desc {
    display: block;
    font-family: var(--font-ui);
    font-size: 0.75rem;
    color: var(--color-mist);
    margin-top: 0.15rem;
  }

  .form-group {
    margin-bottom: 1.5rem;
  }

  .form-group[hidden] {
    display: none;
  }

  label {
    display: block;
    font-family: var(--font-ui);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-bone);
    margin-bottom: 0.4rem;
    letter-spacing: 0.02em;
  }

  .required {
    color: var(--color-ember);
  }

  input[type="text"],
  input[type="email"],
  textarea {
    width: 100%;
    padding: 0.7rem 0.9rem;
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-bone);
    background-color: var(--color-obsidian);
    border: 1px solid rgba(184, 184, 204, 0.2);
    border-radius: 0.25rem;
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  input[type="text"]:focus,
  input[type="email"]:focus,
  textarea:focus {
    outline: none;
    border-color: var(--color-crystal);
    box-shadow: 0 0 0 2px rgba(46, 184, 255, 0.15);
  }

  input[type="text"]::placeholder,
  input[type="email"]::placeholder,
  textarea::placeholder {
    color: rgba(184, 184, 204, 0.4);
  }

  textarea {
    resize: vertical;
    min-height: 4rem;
  }

  .field-hint {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    color: var(--color-mist);
    margin-bottom: 0.6rem;
    line-height: 1.5;
  }

  .field-hint strong {
    color: var(--color-gold);
  }

  /* File upload area */
  .file-upload-area {
    position: relative;
    border: 2px dashed rgba(184, 184, 204, 0.2);
    border-radius: 0.5rem;
    padding: 2rem 1.5rem;
    text-align: center;
    transition:
      border-color 0.2s ease,
      background-color 0.2s ease;
    cursor: pointer;
  }

  .file-upload-area:hover,
  .file-upload-area.dragover {
    border-color: var(--color-crystal);
    background-color: rgba(46, 184, 255, 0.04);
  }

  .file-upload-area input[type="file"] {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
  }

  .file-upload-icon {
    font-size: 2rem;
    display: block;
    margin-bottom: 0.5rem;
  }

  .file-upload-text {
    font-family: var(--font-ui);
    font-size: 0.9rem;
    color: var(--color-mist);
    margin-bottom: 0.25rem;
  }

  .file-upload-text strong {
    color: var(--color-crystal);
  }

  .file-upload-hint {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    color: rgba(184, 184, 204, 0.5);
    margin-bottom: 0;
  }

  .file-upload-selected {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 0.5rem 0;
  }

  .file-name {
    font-family: var(--font-ui);
    font-size: 0.85rem;
    color: var(--color-gold);
  }

  .file-remove {
    background: none;
    border: 1px solid rgba(196, 94, 44, 0.4);
    color: var(--color-ember);
    font-size: 1.1rem;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
    transition: background-color 0.2s ease;
  }

  .file-remove:hover {
    background-color: rgba(196, 94, 44, 0.2);
  }

  /* Validation errors */
  .field-error {
    font-family: var(--font-ui);
    font-size: 0.78rem;
    color: var(--color-ember);
    margin-top: 0.3rem;
    margin-bottom: 0;
    min-height: 0;
  }

  .form-group.invalid input,
  .form-group.invalid textarea,
  .form-group.invalid .file-upload-area {
    border-color: var(--color-ember);
  }

  /* Submit button */
  .submit-btn {
    display: block;
    width: 100%;
    padding: 0.85rem 2rem;
    font-family: var(--font-heading);
    font-size: 1.1rem;
    letter-spacing: 0.04em;
    color: var(--color-void);
    background: linear-gradient(
      135deg,
      var(--color-crystal),
      var(--color-gold)
    );
    border: none;
    border-radius: 0.3rem;
    cursor: pointer;
    transition:
      opacity 0.2s ease,
      transform 0.1s ease;
    margin-top: 0.5rem;
  }

  .submit-btn:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  .submit-btn:active {
    transform: translateY(0);
  }

  .submit-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none;
  }

  /* Form message */
  .form-message {
    text-align: center;
    font-family: var(--font-ui);
    font-size: 0.9rem;
    padding: 1rem;
    border-radius: 0.25rem;
    margin-top: 1.5rem;
  }

  .form-message.success {
    color: var(--color-crystal);
    background-color: rgba(46, 184, 255, 0.1);
    border: 1px solid rgba(46, 184, 255, 0.25);
  }

  .form-message.error {
    color: var(--color-ember);
    background-color: rgba(196, 94, 44, 0.1);
    border: 1px solid rgba(196, 94, 44, 0.25);
  }
</style>

<script
  define:vars={{
    maxFileSizeMB,
    acceptedExtensions,
    artMaxFileSizeMB,
    artAcceptedExtensions,
  }}
>
  const form = document.getElementById("submission-form");
  const fileInput = document.getElementById("manuscript");
  const fileUploadArea = document.getElementById("file-upload-area");
  const fileUploadContent = fileUploadArea.querySelector(
    ".file-upload-content"
  );
  const fileSelected = document.getElementById("file-selected");
  const fileNameEl = document.getElementById("file-name");
  const fileRemoveBtn = document.getElementById("file-remove");
  const submitBtn = document.getElementById("submit-btn");
  const formMessage = document.getElementById("form-message");

  const artInput = document.getElementById("art-attachment");
  const artUploadArea = document.getElementById("art-upload-area");
  const artUploadContent = artUploadArea.querySelector(".file-upload-content");
  const artSelected = document.getElementById("art-selected");
  const artFileNameEl = document.getElementById("art-file-name");
  const artRemoveBtn = document.getElementById("art-remove");

  const allowedExtensions = acceptedExtensions.split(",");
  const maxBytes = maxFileSizeMB * 1024 * 1024;

  const artAllowedExtensions = artAcceptedExtensions.split(",");
  const artMaxBytes = artMaxFileSizeMB * 1024 * 1024;

  // Submission type elements
  const typeSelector = document.getElementById("type-selector");
  const typeOptions = typeSelector.querySelectorAll(".type-option");
  const manuscriptGroup = document.getElementById("manuscript-group");
  const manuscriptReq = document.getElementById("manuscript-req");
  const storyTitleGroup = document.getElementById("story-title-group");
  const storyTitleLabel = document.getElementById("story-title-label");
  const artReq = document.getElementById("art-req");
  const artHint = document.getElementById("art-hint");

  var submissionType = "story";

  function updateFormForType(type) {
    submissionType = type;

    // Update radio button visual state
    typeOptions.forEach(function (opt) {
      var radio = opt.querySelector("input[type='radio']");
      opt.classList.toggle("selected", radio.value === type);
    });

    if (type === "art") {
      // Art only: hide manuscript, make art required
      manuscriptGroup.hidden = true;
      manuscriptReq.hidden = true;
      storyTitleLabel.textContent = "Art Title";
      storyTitleGroup.querySelector("input").placeholder =
        "The title of your artwork";
      artReq.hidden = false;
      artHint.innerHTML =
        "We print in <strong>single-color risograph</strong>, so complex multi-color works may not reproduce well. " +
        "High-contrast, bold linework tends to look best.";
    } else {
      // Story (with optional art): show manuscript, make it required
      manuscriptGroup.hidden = false;
      manuscriptReq.hidden = false;
      storyTitleLabel.textContent = "Story Title";
      storyTitleGroup.querySelector("input").placeholder =
        "The title of your manuscript";
      artReq.hidden = true;
      artHint.innerHTML =
        "Optional — if you have visual art to accompany your story, attach it here. " +
        "We print in <strong>single-color risograph</strong>, so complex multi-color works may not reproduce well. " +
        "High-contrast, bold linework tends to look best.";
    }

    // Clear errors when switching
    ["manuscript", "art-attachment", "story-title"].forEach(clearError);
  }

  typeOptions.forEach(function (opt) {
    opt.addEventListener("click", function () {
      var radio = opt.querySelector("input[type='radio']");
      radio.checked = true;
      updateFormForType(radio.value);
    });
  });

  // Drag-and-drop styling
  fileUploadArea.addEventListener("dragover", (e) => {
    e.preventDefault();
    fileUploadArea.classList.add("dragover");
  });
  fileUploadArea.addEventListener("dragleave", () => {
    fileUploadArea.classList.remove("dragover");
  });
  fileUploadArea.addEventListener("drop", () => {
    fileUploadArea.classList.remove("dragover");
  });

  // File selection handler
  fileInput.addEventListener("change", () => {
    const file = fileInput.files[0];
    if (file) {
      fileNameEl.textContent = file.name;
      fileUploadContent.hidden = true;
      fileSelected.hidden = false;
      clearError("manuscript");
    }
  });

  // Remove file
  fileRemoveBtn.addEventListener("click", (e) => {
    e.preventDefault();
    fileInput.value = "";
    fileUploadContent.hidden = false;
    fileSelected.hidden = true;
  });

  // Art attachment drag-and-drop
  artUploadArea.addEventListener("dragover", (e) => {
    e.preventDefault();
    artUploadArea.classList.add("dragover");
  });
  artUploadArea.addEventListener("dragleave", () => {
    artUploadArea.classList.remove("dragover");
  });
  artUploadArea.addEventListener("drop", () => {
    artUploadArea.classList.remove("dragover");
  });

  // Art file selection handler
  artInput.addEventListener("change", () => {
    const file = artInput.files[0];
    if (file) {
      artFileNameEl.textContent = file.name;
      artUploadContent.hidden = true;
      artSelected.hidden = false;
      clearError("art-attachment");
    }
  });

  // Remove art file
  artRemoveBtn.addEventListener("click", (e) => {
    e.preventDefault();
    artInput.value = "";
    artUploadContent.hidden = false;
    artSelected.hidden = true;
  });

  // Validation helpers
  function showError(fieldId, message) {
    const errorEl = document.getElementById(`${fieldId}-error`);
    const group = errorEl.closest(".form-group");
    errorEl.textContent = message;
    group.classList.add("invalid");
  }

  function clearError(fieldId) {
    const errorEl = document.getElementById(`${fieldId}-error`);
    if (!errorEl) return;
    const group = errorEl.closest(".form-group");
    errorEl.textContent = "";
    group.classList.remove("invalid");
  }

  function validateFile(file, required) {
    if (!file) return required ? "Please select a manuscript file." : null;

    const ext = "." + file.name.split(".").pop().toLowerCase();
    if (!allowedExtensions.includes(ext)) {
      return `File type "${ext}" is not accepted. Please upload a ${allowedExtensions.join(", ")} file.`;
    }

    if (file.size > maxBytes) {
      return `File is too large (${(file.size / 1024 / 1024).toFixed(1)}MB). Maximum size is ${maxFileSizeMB}MB.`;
    }

    return null;
  }

  function validateArtFile(file, required) {
    if (!file) return required ? "Please select an art file." : null;

    const ext = "." + file.name.split(".").pop().toLowerCase();
    if (!artAllowedExtensions.includes(ext)) {
      return `File type "${ext}" is not accepted. Please upload a ${artAllowedExtensions.join(", ")} file.`;
    }

    if (file.size > artMaxBytes) {
      return `File is too large (${(file.size / 1024 / 1024).toFixed(1)}MB). Maximum size is ${artMaxFileSizeMB}MB.`;
    }

    return null;
  }

  // Form submission
  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    formMessage.hidden = true;
    let hasError = false;

    // Clear previous errors
    [
      "author-name",
      "email",
      "story-title",
      "manuscript",
      "art-attachment",
    ].forEach(clearError);

    // Validate author name
    const authorName = form.authorName.value.trim();
    if (!authorName) {
      showError("author-name", "Author name is required.");
      hasError = true;
    }

    // Validate email
    const email = form.email.value.trim();
    if (!email) {
      showError("email", "Email is required.");
      hasError = true;
    } else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      showError("email", "Please enter a valid email address.");
      hasError = true;
    }

    // Validate story title
    const storyTitle = form.storyTitle.value.trim();
    if (!storyTitle) {
      showError("story-title", "Story title is required.");
      hasError = true;
    }

    // Validate file (required for story, not for art-only)
    const isStory = submissionType === "story";
    const file = fileInput.files[0];
    if (isStory) {
      const fileError = validateFile(file, true);
      if (fileError) {
        showError("manuscript", fileError);
        hasError = true;
      }
    }

    // Validate art attachment (required for art-only, optional for story)
    const artFile = artInput.files[0];
    const artError = validateArtFile(artFile, !isStory);
    if (artError) {
      showError("art-attachment", artError);
      hasError = true;
    }

    if (hasError) {
      // Scroll to first error
      const firstInvalid = form.querySelector(".form-group.invalid");
      if (firstInvalid) {
        firstInvalid.scrollIntoView({ behavior: "smooth", block: "center" });
      }
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = "Sending...";

    try {
      // Read manuscript as base64 if provided
      var fileBase64 = null;
      if (file) {
        fileBase64 = await new Promise(function (resolve, reject) {
          var reader = new FileReader();
          reader.onload = function () {
            resolve(reader.result.split(",")[1]);
          };
          reader.onerror = function () {
            reject(new Error("Failed to read file."));
          };
          reader.readAsDataURL(file);
        });
      }

      // Read art file as base64 if provided
      var artBase64 = null;
      if (artFile) {
        artBase64 = await new Promise(function (resolve, reject) {
          var reader = new FileReader();
          reader.onload = function () {
            resolve(reader.result.split(",")[1]);
          };
          reader.onerror = function () {
            reject(new Error("Failed to read art file."));
          };
          reader.readAsDataURL(artFile);
        });
      }

      const payload = {
        submissionType: submissionType,
        authorName: authorName,
        email: email,
        storyTitle: storyTitle,
        coverLetter: form.coverLetter.value.trim(),
        additionalNotes: form.additionalNotes.value.trim(),
      };
      if (fileBase64) {
        payload.manuscript = { name: file.name, base64: fileBase64 };
      }
      if (artBase64) {
        payload.artAttachment = { name: artFile.name, base64: artBase64 };
      }

      const res = await fetch("/api/submit", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });
      const data = await res.json();

      if (!res.ok) {
        throw new Error(data.error || "Something went wrong.");
      }

      form.hidden = true;
      document.getElementById("intro-text").hidden = true;
      formMessage.textContent =
        "Your submission has been received! We'll be in touch within 60 days.";
      formMessage.className = "form-message success";
      formMessage.hidden = false;
    } catch (err) {
      formMessage.textContent =
        err.message || "Submission failed. Please try again.";
      formMessage.className = "form-message error";
      formMessage.hidden = false;
      submitBtn.disabled = false;
      submitBtn.textContent = "Send Into the Glass";
    }

    formMessage.scrollIntoView({ behavior: "smooth", block: "center" });
  });

  // Clear errors on input
  form.querySelectorAll("input, textarea").forEach((el) => {
    el.addEventListener("input", () => {
      const group = el.closest(".form-group");
      const errorEl = group?.querySelector(".field-error");
      if (errorEl) {
        errorEl.textContent = "";
        group.classList.remove("invalid");
      }
    });
  });
</script>
