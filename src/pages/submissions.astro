---
import BaseLayout from "../layouts/BaseLayout.astro";

const isOpen = true; // Toggle submissions open/closed
---

<BaseLayout
  title="Submissions — Scrying Glass"
  description="Submission guidelines for Scrying Glass, a literary journal of sword & sorcery fiction."
>
  <h1>Submissions</h1>

  <div class:list={["status-banner", { open: isOpen, closed: !isOpen }]}>
    {isOpen ? "Submissions are OPEN" : "Submissions are currently CLOSED"}
  </div>

  <section class="section">
    <h2>What We Publish</h2>
    <p>
      We publish <strong>sword &amp; sorcery</strong>, <strong
        >dark fantasy</strong
      >, and
      <strong>weird fiction</strong> — short stories in the tradition of the great
      pulp fantasists. Think thieves in cursed cities, sorcerers bargaining with things
      best left unbargained with, and warriors facing odds that no reasonable person
      would face.
    </p>
    <ul>
      <li><strong>Word count:</strong> 1,500–5,000 words</li>
      <li>
        <strong>Genre:</strong> Sword &amp; sorcery, dark fantasy, weird fiction
      </li>
      <li><strong>No:</strong> Novels, excerpts, or AI-generated text</li>
      <li>
        We may make exceptions for shorter fiction and poetry (and maybe even
        longer tales); if you feel like you have a winner, send it in
      </li>
    </ul>
    <p>
      We read every submission and encourage you to submit your highest-quality
      work.
    </p>
  </section>

  <section class="section">
    <h2>Formatting</h2>
    <ul>
      <li>Standard manuscript format</li>
      <li>Accepted file types: .doc, .docx, .rtf</li>
      <li>Double-spaced, 12pt font (Times New Roman or similar)</li>
      <li>
        Include your name (pen names are fine), word count, and story title in
        the document header
      </li>
    </ul>
  </section>

  <section class="section">
    <h2>How to Submit</h2>
    <p>
      Send your manuscript as an attachment to
      <a href="mailto:submissions@scryingglass.pub"
        >submissions@scryingglass.pub</a
      >. Include a brief cover letter with your bio (2–3 sentences) and any
      relevant publication credits.
    </p>
    <p>No need for a synopsis — we'd rather be surprised.</p>
  </section>

  <section class="section">
    <h2>Response Times</h2>
    <p>
      We aim to respond within <strong>60 days</strong>. If you haven't heard
      from us after 90 days, feel free to query.
    </p>
  </section>

  <section class="section">
    <h2>Payment &amp; Rights</h2>
    <ul>
      <li><strong>Payment:</strong> [Rate TBD] per story</li>
      <li>
        <strong>Rights:</strong> First world English-language rights, exclusive for
        6 months
      </li>
      <li>Rights revert to the author after the exclusivity period</li>
    </ul>
  </section>

  <section class="section">
    <h2>Simultaneous &amp; Multiple Submissions</h2>
    <p>
      <strong>Simultaneous submissions:</strong> Yes, but please notify us immediately
      if your story is accepted elsewhere.
    </p>
    <p>
      <strong>Multiple submissions:</strong> One story at a time, please. Let us give
      your tale the attention it deserves.
    </p>
  </section>
</BaseLayout>

<style>
  h1 {
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .status-banner {
    text-align: center;
    font-family: var(--font-ui);
    font-size: 0.9rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.75rem 1.5rem;
    border-radius: 0.25rem;
    margin-bottom: 2rem;
  }

  .status-banner.open {
    background-color: rgba(30, 160, 255, 0.12);
    color: var(--color-crystal);
    border: 1px solid rgba(30, 160, 255, 0.25);
  }

  .status-banner.closed {
    background-color: rgba(196, 94, 44, 0.15);
    color: var(--color-ember);
    border: 1px solid rgba(196, 94, 44, 0.3);
  }

  strong {
    color: var(--color-bone);
  }
</style>
