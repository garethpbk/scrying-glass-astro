---
interface Props {
  size?: string;
}

const { size = '12rem' } = Astro.props;
---

<div class="orb-container" style={`--orb-size: ${size}`}>
  <div class="orb">
    <div class="orb-depth"></div>
    <div class="orb-inner"></div>
    <div class="orb-mist"></div>
    <div class="orb-shine"></div>
  </div>
</div>

<script>
  const orb = document.querySelector('.orb') as HTMLElement;
  if (!orb) throw new Error('Orb not found');

  const container = orb.parentElement!;

  function updateOrb(e: MouseEvent) {
    const rect = container.getBoundingClientRect();
    const centerX = rect.left + rect.width / 2;
    const centerY = rect.top + rect.height / 2;

    const dx = (e.clientX - centerX) / window.innerWidth;
    const dy = (e.clientY - centerY) / window.innerHeight;

    const tiltX = dy * -15;
    const tiltY = dx * 15;

    const lightX = 35 + dx * 30;
    const lightY = 35 + dy * 30;

    const shineX = 20 - dx * 15;
    const shineY = 12 - dy * 15;

    const dist = Math.sqrt(dx * dx + dy * dy);
    const proximity = Math.max(0, 1 - dist * 2.5);
    const glowIntensity = 0.3 + proximity * 0.4;
    const outerGlow = 0.15 + proximity * 0.3;

    orb.style.transform = `rotateX(${tiltX}deg) rotateY(${tiltY}deg)`;
    orb.style.background = `radial-gradient(
      circle at ${lightX}% ${lightY}%,
      rgba(40, 180, 255, ${0.35 + proximity * 0.35}) 0%,
      rgba(20, 120, 220, 0.18) 25%,
      rgba(10, 60, 140, 0.12) 45%,
      rgba(8, 15, 30, 0.95) 70%,
      #0a0f1e 100%
    )`;
    orb.style.boxShadow = `
      0 0 ${40 + proximity * 30}px rgba(30, 160, 255, ${glowIntensity}),
      0 0 ${80 + proximity * 60}px rgba(20, 120, 240, ${outerGlow}),
      0 0 ${120 + proximity * 80}px rgba(10, 80, 200, ${outerGlow * 0.4}),
      inset 0 0 30px rgba(40, 180, 255, ${0.2 + proximity * 0.25})
    `;

    // Depth layer — icy white core
    const depth = orb.querySelector('.orb-depth') as HTMLElement;
    if (depth) {
      depth.style.background = `radial-gradient(
        circle at ${lightX + 5}% ${lightY + 5}%,
        rgba(200, 240, 255, ${0.1 + proximity * 0.15}) 0%,
        rgba(40, 160, 255, ${0.06 + proximity * 0.1}) 40%,
        transparent 70%
      )`;
    }

    // Inner swirl — electric blue
    const inner = orb.querySelector('.orb-inner') as HTMLElement;
    if (inner) {
      inner.style.background = `radial-gradient(
        circle at ${lightX}% ${lightY}%,
        rgba(80, 200, 255, ${0.18 + proximity * 0.22}) 0%,
        rgba(20, 100, 220, ${0.1 + proximity * 0.15}) 40%,
        transparent 70%
      )`;
    }

    // Shift shine
    const shine = orb.querySelector('.orb-shine') as HTMLElement;
    if (shine) {
      shine.style.top = `${shineY}%`;
      shine.style.left = `${shineX}%`;
    }
  }

  document.addEventListener('mousemove', updateOrb);
</script>

<style>
  .orb-container {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 2rem 0;
    perspective: 600px;
  }

  .orb {
    position: relative;
    width: var(--orb-size);
    height: var(--orb-size);
    border-radius: 50%;
    background: radial-gradient(
      circle at 35% 35%,
      rgba(40, 180, 255, 0.45) 0%,
      rgba(20, 120, 220, 0.18) 25%,
      rgba(10, 60, 140, 0.12) 45%,
      rgba(8, 15, 30, 0.95) 70%,
      #0a0f1e 100%
    );
    box-shadow:
      0 0 40px rgba(30, 160, 255, 0.35),
      0 0 80px rgba(20, 120, 240, 0.18),
      0 0 120px rgba(10, 80, 200, 0.08),
      inset 0 0 30px rgba(40, 180, 255, 0.2);
    animation: pulse 4s ease-in-out infinite;
    transition: transform 0.15s ease-out, background 0.15s ease-out, box-shadow 0.3s ease-out;
    transform-style: preserve-3d;
    will-change: transform, box-shadow;
  }

  .orb:hover {
    animation-play-state: paused;
  }

  .orb-depth {
    position: absolute;
    inset: 10%;
    border-radius: 50%;
    background: radial-gradient(
      circle at 45% 45%,
      rgba(200, 240, 255, 0.1) 0%,
      rgba(40, 160, 255, 0.06) 40%,
      transparent 70%
    );
    transition: background 0.2s ease-out;
  }

  .orb-inner {
    position: absolute;
    inset: 15%;
    border-radius: 50%;
    background: radial-gradient(
      circle at 40% 40%,
      rgba(80, 200, 255, 0.22) 0%,
      rgba(20, 100, 220, 0.1) 40%,
      transparent 70%
    );
    animation: swirl 8s ease-in-out infinite reverse;
    transition: background 0.2s ease-out;
  }

  .orb-mist {
    position: absolute;
    inset: 5%;
    border-radius: 50%;
    background: radial-gradient(
      circle at 60% 60%,
      rgba(30, 160, 255, 0.08) 0%,
      rgba(10, 80, 200, 0.03) 40%,
      transparent 60%
    );
    animation: drift 12s ease-in-out infinite;
    opacity: 0.6;
  }

  .orb-shine {
    position: absolute;
    top: 12%;
    left: 20%;
    width: 30%;
    height: 20%;
    border-radius: 50%;
    background: radial-gradient(
      ellipse,
      rgba(220, 245, 255, 0.4) 0%,
      rgba(180, 230, 255, 0.15) 40%,
      transparent 70%
    );
    transform: rotate(-30deg);
    transition: top 0.15s ease-out, left 0.15s ease-out;
    pointer-events: none;
  }

  @keyframes pulse {
    0%, 100% {
      box-shadow:
        0 0 40px rgba(30, 160, 255, 0.35),
        0 0 80px rgba(20, 120, 240, 0.18),
        0 0 120px rgba(10, 80, 200, 0.08),
        inset 0 0 30px rgba(40, 180, 255, 0.2);
    }
    50% {
      box-shadow:
        0 0 60px rgba(30, 160, 255, 0.55),
        0 0 120px rgba(20, 120, 240, 0.3),
        0 0 180px rgba(10, 80, 200, 0.12),
        inset 0 0 40px rgba(40, 180, 255, 0.35);
    }
  }

  @keyframes swirl {
    0%, 100% {
      transform: rotate(0deg) scale(1);
      opacity: 0.6;
    }
    50% {
      transform: rotate(180deg) scale(1.1);
      opacity: 1;
    }
  }

  @keyframes drift {
    0%, 100% {
      transform: translate(0, 0) scale(1);
      opacity: 0.4;
    }
    33% {
      transform: translate(5%, -3%) scale(1.05);
      opacity: 0.7;
    }
    66% {
      transform: translate(-3%, 5%) scale(0.95);
      opacity: 0.5;
    }
  }
</style>
