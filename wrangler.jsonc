{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "scrying-glass-astro",
  "compatibility_date": "2025-03-01",
  "observability": {
    "enabled": true
  },
  "main": "dist/_worker.js/index.js",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": "dist"
  }
}
